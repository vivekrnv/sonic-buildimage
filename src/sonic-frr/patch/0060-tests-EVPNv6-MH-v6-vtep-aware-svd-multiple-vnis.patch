+        1000: 1000,
+        1001: 1001,
+        1002: 1002,
+        1003: 1003,
+        4000: 4000,
+        4001: 4001,
+    }
+    for vid, vni in vni_map.items():
+        # First add the VLAN membership on vxlan48, then add tunnel_info id
+        node.run(f"/sbin/bridge vlan add dev vxlan48 vid {vid}")
