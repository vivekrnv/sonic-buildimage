@oe.command('speed')
@click.argument('oe', metavar='<OE Number Ranges from {} to {}>'.format(OE_INDEX_LIST[0], OE_INDEX_LIST[-1]), required=False)
def show_speed(oe):
    """Display speed of OE"""
    global cpo_util
    if cpo_util == None:
        click.echo("Not supported!")
        return -1
    oe_list, msg = _get_oe_list(oe)
    if oe_list == None:
        click.echo(msg)
        return -1
    port_index_list = cpo_util.get_port_index_list()
    for port_index in port_index_list:
        speed = cpo_util.get_speed(port_index)
        click.echo("{}: {}".format(port_index, speed))

