# rlm: 1-16
@rlm.command('lpmode')
@click.argument('rlm', metavar='<RLM Number Ranges from {} to {}>'.format(RLM_INDEX_LIST[0], RLM_INDEX_LIST[-1]), required=True)
@click.argument('mode', metavar='<RLM Power Mode>', required=True, type=click.Choice(['full-power', 'half-power']))
def rlm_lpmode(rlm, mode):
    """Config RLM laser power-mode"""
    rlm_index_list, msg = _get_rlm_list(rlm)
    if rlm_index_list == None:
        click.echo(msg)
        return -1
    threads = list()
    for rlm_index in rlm_index_list:
        cmd = (str({"rlm_index_list":[rlm_index], "cmd":"set_rlm_power_mode", "power_mode": mode}))
        threads.append(threading.Thread(target=send_cmd, args=(cmd,)))
    for t in threads:
        t.start()
    for t in threads:
        t.join()

